# RAG System Environment Configuration
# 复制此文件为 .env 并填入真实值
# ⚠️ 切勿将 .env 提交到版本控制

# OpenAI 兼容 API
API_KEY=sk-your-api-key-here
BASE_URL=https://api.openai.com/v1

# LLM 模型（可选，默认 deepseek-chat）
# LLM_MODEL=deepseek-chat

# 温度参数（可选，默认 0.1）
# LLM_TEMPERATURE=0.1

# Top-K 范围（可选，默认 3-20）
# LLM_TOP_K_MIN=3
# LLM_TOP_K_MAX=20

# Graph RAG Alpha（可选，默认 0.7）
# ALPHA=0.7
