# RAG System Environment Configuration
# 复制此文件为 .env 并填入真实值
# ⚠️ 切勿将 .env 提交到版本控制

# OpenAI 兼容 API
API_KEY=sk-your-api-key-here
BASE_URL=https://api.openai.com/v1

# LLM 模型（可选，默认 deepseek-chat）
# LLM_MODEL=deepseek-chat

# 温度参数（可选，默认 0.1）
# LLM_TEMPERATURE=0.1

# Top-K 范围（可选，默认 3-20）
# LLM_TOP_K_MIN=3
# LLM_TOP_K_MAX=20

# Graph RAG Alpha（可选，默认 0.7）
# ALPHA=0.7

# Embedding 模型路径（可选）
# 默认优先从本地缓存加载；不可用时通过 ModelScope 下载 all-MiniLM-L6-v2
# 国内网络可以直接使用 ModelScope，或先下载到本地后设置此路径：
#   pip install modelscope
#   python -c "from modelscope import snapshot_download; snapshot_download('sentence-transformers/all-MiniLM-L6-v2', cache_dir='models')"
# EMBEDDING_MODEL_PATH=./models/sentence-transformers/all-MiniLM-L6-v2

# 远程端点安全：远程 Base URL 默认必须使用 HTTPS。
# 仅本机开发端点允许 http://localhost；不要把文档密钥放入索引。
# MNEME_ALLOW_INSECURE_HTTP=1

# 文档与远程上下文资源上限（按需调整，必须为正整数）
# MNEME_MAX_DOCUMENT_BYTES=52428800
# MNEME_MAX_PDF_PAGES=2000
# MNEME_MAX_REMOTE_CONTEXT_CHARS=60000
# MNEME_DOCUMENT_ROOT=./documents
